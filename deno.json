{
  "workspace": ["./apps/cli", "./apps/docs"],
  "nodeModulesDir": "auto",
  "tasks": {
    "dv": "deno task --filter @seshat/dv dv",
    "test": "deno test -A",
    "check": "deno task --filter * check"
  },
  "imports": {
    "@std/cli": "jsr:@std/cli@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@std/front-matter": "jsr:@std/front-matter@^1",
    "@std/semver": "jsr:@std/semver@^1"
  },
  "fmt": {
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": { "tags": ["recommended"] }
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  }
}
