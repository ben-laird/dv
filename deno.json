{
  "workspace": ["./apps/cli", "./apps/docs"],
  "nodeModulesDir": "auto",
  "tasks": {
    "dv": "deno task --filter @seshat/dv dv",
    "test": "deno test -A",
    "check": "deno task --filter '@seshat/*' check",
    "fmt": "deno run -A npm:@biomejs/biome@2.4.15 format --write .",
    "fmt:check": "deno run -A npm:@biomejs/biome@2.4.15 format .",
    "lint": "deno task lint:biome && deno task lint:deno",
    "lint:biome": "deno run -A npm:@biomejs/biome@2.4.15 check .",
    "lint:deno": "deno lint",
    "lint:fix": "deno run -A npm:@biomejs/biome@2.4.15 check --write . && deno lint",
    "install": "deno run -A apps/cli/src/scripts/install-dev-shim.ts",
    "uninstall": "deno run -A apps/cli/src/scripts/install-dev-shim.ts --uninstall",
    "schemas:generate": "deno run -A apps/cli/src/scripts/generate-schemas.ts generate",
    "schemas:check": "deno run -A apps/cli/src/scripts/generate-schemas.ts check",
    "verify": "deno task fmt:check && deno task lint && deno task check && deno task test && deno task schemas:check"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/cli": "jsr:@std/cli@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@std/front-matter": "jsr:@std/front-matter@^1",
    "@std/semver": "jsr:@std/semver@^1",
    "zod": "npm:zod@^4"
  },
  "lint": {
    "rules": { "tags": ["recommended"] }
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "allowScripts": ["npm:@biomejs/biome"]
}
