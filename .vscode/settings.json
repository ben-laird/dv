{
  // YAML schemas for editor autocomplete. The Red Hat YAML extension
  // (`redhat.vscode-yaml`) picks these up; each file also carries a
  // `# yaml-language-server:` modeline for editors that read those.
  //
  // Record files (.dv/records/*.md) are markdown-with-YAML-
  // frontmatter, which is awkward for the YAML extension to schema-
  // validate directly. The Zod-driven validator in `dv validate`
  // covers that gap.
  "yaml.schemas": {
    "./specs/schemas/config.json": [
      ".dv/config.yaml",
      "**/.dv/config.yaml"
    ],
    "./specs/schemas/rename-ledger.json": [
      ".dv/renames.yaml",
      "**/.dv/renames.yaml"
    ]
  }
}
